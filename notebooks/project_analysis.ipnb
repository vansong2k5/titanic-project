{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "c877ab97",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import OneHotEncoder, RobustScaler\n",
    "from lazypredict.Supervised import LazyClassifier\n",
    "from sklearn.pipeline import Pipeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "54ed5fa5",
   "metadata": {},
   "outputs": [],
   "source": [
    "data_df = pd.read_csv('../data/train.csv', index_col='PassengerId')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "3a09a304",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "Embarked\n",
       "S    644\n",
       "C    168\n",
       "Q     77\n",
       "Name: count, dtype: int64"
      ]
     },
     "execution_count": 3,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "data_df.Embarked.value_counts()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "8d91c316",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Age         177\n",
      "Cabin       687\n",
      "Embarked      2\n",
      "dtype: int64\n"
     ]
    }
   ],
   "source": [
    "# Fill the data with sum miss value > 0\n",
    "missing_data = data_df.isnull().sum()\n",
    "print(missing_data[missing_data > 0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "48b7005c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Lấy ra target cần dự đoán\n",
    "target = 'Survived'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "b66f4be8",
   "metadata": {},
   "outputs": [],
   "source": [
    "x = data_df.drop(columns=[target], axis = 1)\n",
    "y = data_df[target]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "fb99372a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Stratify ( phân chia để k bị lệch data giữa train và test)\n",
    "X_train, X_test, Y_train, Y_test = train_test_split(x,y, train_size = 0.8, random_state=1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "e5ad915b",
   "metadata": {},
   "outputs": [],
   "source": [
    "embarked_mode = X_train['Embarked'].mode()[0]\n",
    "\n",
    "X_train['Embarked'] = X_train['Embarked'].fillna(embarked_mode)\n",
    "X_test['Embarked'] = X_test['Embarked'].fillna(embarked_mode)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "31cb936f",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train['Deck'] = X_train['Cabin'].apply(lambda x: 'U' if pd.isna(x) else str(x)[0])\n",
    "X_test['Deck'] = X_test['Cabin'].apply(lambda x: 'U' if pd.isna(x) else str(x)[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4399cb28",
   "metadata": {},
   "outputs": [],
   "source": [
    "age_group_median = X_train.groupby(['Sex', 'Pclass'])['Age'].median()\n",
    "\n",
    "global_age_median = X_train['Age'].median()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f56a3353",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fill_age(row):\n",
    "    if pd.notna(row['Age']):\n",
    "        return row['Age']\n",
    "    \n",
    "    key = (row['Sex'], row['Pclass'])\n",
    "    \n",
    "    if key in age_group_median.index and pd.notna(age_group_median.loc[key]):\n",
    "        return age_group_median.loc[key]\n",
    "    \n",
    "    return global_age_median"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "20843620",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train['Age'] = X_train.apply(fill_age, axis=1)\n",
    "X_test['Age'] = X_test.apply(fill_age, axis=1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f6839703",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sex\n",
    "X_train['Sex'] = X_train['Sex'].map({'male': 0, 'female': 1})\n",
    "X_test['Sex'] = X_test['Sex'].map({'male': 0, 'female': 1})\n",
    "\n",
    "# Title\n",
    "X_train['Title'] = X_train['Name'].str.extract(r' ([A-Za-z]+)\\.', expand=False)\n",
    "X_test['Title'] = X_test['Name'].str.extract(r' ([A-Za-z]+)\\.', expand=False)\n",
    "\n",
    "title_mapping = {'Mlle': 'Miss', 'Ms': 'Miss', 'Mme': 'Mrs'}\n",
    "rare_titles = ['Lady', 'Countess', 'Capt', 'Col', 'Don', 'Dr', 'Major', 'Rev', 'Sir', 'Jonkheer', 'Dona']\n",
    "\n",
    "for data in [X_train, X_test]:\n",
    "    data['Title'] = data['Title'].replace(title_mapping)\n",
    "    data['Title'] = data['Title'].replace(rare_titles, 'Rare')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1a836878",
   "metadata": {},
   "outputs": [],
   "source": [
    "# học prefix hiếm từ train\n",
    "train_ticket_prefix = X_train['Ticket'].str.replace(r'[0-9./]', '', regex=True).str.strip()\n",
    "train_ticket_prefix = train_ticket_prefix.replace('', 'NONE')\n",
    "\n",
    "prefix_counts = train_ticket_prefix.value_counts()\n",
    "rare_prefixes = prefix_counts[prefix_counts < 10].index.tolist()\n",
    "\n",
    "# áp dụng cho train và test\n",
    "def make_ticket_prefix(ticket, rare_prefixes):\n",
    "    prefix = pd.Series([ticket]).str.replace(r'[0-9./]', '', regex=True).str.strip().iloc[0]\n",
    "    prefix = 'NONE' if prefix == '' else prefix\n",
    "    return 'RARE' if prefix in rare_prefixes else prefix\n",
    "\n",
    "X_train['TicketPrefix'] = X_train['Ticket'].apply(lambda x: make_ticket_prefix(x, rare_prefixes))\n",
    "X_test['TicketPrefix'] = X_test['Ticket'].apply(lambda x: make_ticket_prefix(x, rare_prefixes))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "6b702752",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train['Family_Size'] = X_train['SibSp'] + X_train['Parch'] + 1\n",
    "X_test['Family_Size'] = X_test['SibSp'] + X_test['Parch'] + 1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "48abc0ed",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train['IsAlone'] = (X_train['Family_Size'] == 1).astype(int)\n",
    "X_test['IsAlone'] = (X_test['Family_Size'] == 1).astype(int)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "75bee7b1",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train['Surname'] = X_train['Name'].str.split(',').str[0]\n",
    "X_test['Surname'] = X_test['Name'].str.split(',').str[0]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "c79d6b36",
   "metadata": {},
   "outputs": [],
   "source": [
    "surname_counts = X_train['Surname'].value_counts()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "a8fc1d58",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train['SurnameCount'] = X_train['Surname'].map(surname_counts)\n",
    "\n",
    "X_test['SurnameCount'] = X_test['Surname'].map(surname_counts)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d5e3e481",
   "metadata": {},
   "outputs": [],
   "source": [
    "cols_to_drop = ['Cabin', 'Ticket', 'Name']\n",
    "X_train = X_train.drop(columns=cols_to_drop, errors='ignore')\n",
    "X_test = X_test.drop(columns=cols_to_drop, errors='ignore')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "4a0a6df2",
   "metadata": {},
   "outputs": [
    {
