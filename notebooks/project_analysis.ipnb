    "X_train.info()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "4ddcb7f6",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import RobustScaler\n",
    "\n",
    "num_feature = ['Age', 'Fare', 'SurnameCount', 'Family_Size']\n",
    "\n",
    "scaler = RobustScaler()\n",
    "\n",
    "\n",
    "X_train[num_feature] = scaler.fit_transform(X_train[num_feature])\n",
    "X_test[num_feature] = scaler.transform(X_test[num_feature])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "04d8a043",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import OneHotEncoder\n",
    "\n",
    "cat_features = ['Embarked', 'Title', 'Deck', 'Surname', 'IsAlone', 'TicketPrefix']\n",
    "\n",
    "encoder = OneHotEncoder(handle_unknown='ignore', sparse_output=False)\n",
    "\n",
    "# fit + transform\n",
    "X_train = encoder.fit_transform(X_train[cat_features])\n",
    "X_test = encoder.transform(X_test[cat_features])"
   ]
  },
  {
